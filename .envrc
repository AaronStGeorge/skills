# hrx-kernels-ws workspace environment.
#
# Activates the workspace virtualenv (creating it on first entry) and performs the
# editable install described in README.md. Mirrors the structure of the
# llamacpp-devws .envrc, minus the ROCm/PATH setup.

if [ "${HRX_KERNELS_WS_SKIP_VENV:-0}" != "1" ]; then
  if [ ! -f "$PWD/.venv/bin/activate" ]; then
    "${PYTHON:-python3}" -m venv "$PWD/.venv" --prompt "${PWD##*/}"
  fi

  source "$PWD/.venv/bin/activate"

  # Editable install of the shared library (agent-tools: assemblyline, buildlib,
  # builds), per README.md. Guarded on importability so it runs once on a fresh
  # venv and is skipped on subsequent directory entries (.envrc runs on every cd).
  if ! python -c "import buildlib" 2>/dev/null; then
    pip install -e "$PWD/lib/python" --config-settings editable_mode=compat
  fi
fi
